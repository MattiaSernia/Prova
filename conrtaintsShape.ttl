@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix ao:       <https://belval.fr/ao/ontology#> .
@prefix shapes:   <https://belval.fr/ao/shapes#> .

shapes:ConstraintsShape 
    a sh:NodeShape ;
    sh:targetClass ao:Constraint ;

    sh:property [
        sh:path ao:constraintType ;
        sh:in ( "Budgetary" "Temporal" "Technical" "Regulatory" "Environmental" "Sovereignty" ) ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path ao:subject ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path ao:predicate ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path ao:object ;
        sh:minCount 1 ;
    ] .
<http://example.org/extraction/req/extraction1> {
    req:req1 a ex:Requirement ;
        ns1:implement <http://example.org/node/artificial_intelligence_solution_of_assistance_to_the_agents> ;
        rdf:subject <http://example.org/node/city_of_belval> .

    req:req10 a ex:Requirement ;
        ns1:reduce <http://example.org/node/times_of_processing> ;
        ex:category ex:operations ;
        rdf:subject <http://example.org/node/agents> .

    req:req11 a ex:Requirement ;
        ns1:design <http://example.org/node/solution> ;
        rdf:subject <http://example.org/node/client> .


        rdf:subject <http://example.org/node/client> .

    req:req14 a ex:Requirement ;
        ns1:provide <http://example.org/node/intelligent_assistance_tool> ;
        ex:category ex:administration ;
        ex:priority ex:must ;
        rdf:subject <http://example.org/node/agents> .

    req:req15 a ex:Requirement ;
        ns1:accompany <http://example.org/node/administrative_activities> ;
        ex:category ex:administration ;
        ex:priority ex:must ;

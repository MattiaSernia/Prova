<http://esempio.org/nodo/Englishliteraturebooks> a ns1:Person,
        rdfs:Resource,
        owl:Thing ;
    ns1:is_called "Englishliteraturebooks" ;
    ns1:knows <http://esempio.org/nodo/Bob> ;
    ns1:mentioned_in <http://esempio.org/nodo/Message_3> .

<http://esempio.org/nodo/Message_10> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "I think she's been invited by some friends, but I'll have to ask her first. Mattia's always saying we should just stay home and have a quiet night in, but that's not really what I'm in the mood for." ;
    ns1:mentions <http://esempio.org/nodo/Frank>,
        <http://esempio.org/nodo/Mattia> ;
    ns1:received_at "2026-03-20T15:50:50.912000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Bob> ;
    ns1:sended_at "2026-03-20T15:50:50.912000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Frank> .

<http://esempio.org/nodo/Message_11> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "Yeah, I'm sure you'll have a great time with Liam's help. Do you think Alice's going to wear that new dress she's been wanting to try out?" ;
    ns1:mentions <http://esempio.org/nodo/Bob>,
        <http://esempio.org/nodo/Liam> ;
    ns1:sended_at "2026-03-20T15:50:52.565000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Bob> .

<http://esempio.org/nodo/Message_3> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "I'm doing great, just keeping up with my English literature books. I'm sure you'll do well on your exam." ;
    ns1:mentions <http://esempio.org/nodo/Bob>,
        <http://esempio.org/nodo/Englishliteraturebooks> ;
    ns1:received_at "2026-03-20T15:50:39.612000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Frank> ;
    ns1:sended_at "2026-03-20T15:50:39.612000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Bob> .

<http://esempio.org/nodo/Message_7> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "It's always a bit of a struggle, but it's worth it in the end. Do you think Liam will really help you with your math problems?" ;
    ns1:mentions <http://esempio.org/nodo/Bob>,
        <http://esempio.org/nodo/Liam> ;
    ns1:received_at "2026-03-20T15:50:45.898000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Frank> ;
    ns1:sended_at "2026-03-20T15:50:45.897000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Bob> .

<http://esempio.org/nodo/Message_8> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "Liam's always willing to lend a hand, I'm sure he'll do well on the exam. I just hope he doesn't make me do all the work, that would be a disaster." ;
    ns1:mentions <http://esempio.org/nodo/Frank>,
        <http://esempio.org/nodo/Liam> ;
    ns1:received_at "2026-03-20T15:50:47.479000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Bob> ;
    ns1:sended_at "2026-03-20T15:50:47.479000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Frank> .

<http://esempio.org/nodo/you> a ns1:Person,

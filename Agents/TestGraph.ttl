ns1:hasText a rdf:Property ;
    rdfs:subPropertyOf ns1:hasText ;
    owl:equivalentProperty ns1:hasText .

ns1:is_called a rdf:Property,
        rdfs:Resource ;
    rdfs:domain ns1:Person,
        owl:Thing ;
    rdfs:subPropertyOf ns1:is_called ;
    owl:equivalentProperty ns1:is_called .

ns1:knows a rdf:Property,
        rdfs:Resource,
        owl:SymmetricProperty ;
    rdfs:domain ns1:Person,
        owl:Thing ;
    rdfs:range ns1:Person,
        owl:Thing ;
    rdfs:subPropertyOf ns1:knows ;
    owl:equivalentProperty ns1:knows .

ns1:mentioned_in a rdf:Property,
        rdfs:Resource ;
    rdfs:subPropertyOf ns1:mentioned_in ;
    owl:equivalentProperty ns1:mentioned_in ;
    owl:inverseOf ns1:mentions .

ns1:received_at a rdf:Property,
        rdfs:Resource ;
    rdfs:range ns1:Person,
        owl:Thing ;
    rdfs:subPropertyOf ns1:received_at ;
    owl:equivalentProperty ns1:received_at .

ns1:received_by a rdf:Property,
        rdfs:Resource ;
    rdfs:domain ns1:Message ;
    rdfs:range ns1:Person,
        ns1:User,
        owl:Thing ;
    rdfs:subPropertyOf ns1:received_by ;
    owl:equivalentProperty ns1:received_by .

ns1:sended_at a rdf:Property ;
    rdfs:subPropertyOf ns1:sended_at ;
    owl:equivalentProperty ns1:sended_at .

ns1:sended_by a rdf:Property,
        rdfs:Resource ;
    rdfs:domain ns1:Message ;
    rdfs:range ns1:Person,
        ns1:User,
        owl:Thing ;
    rdfs:subPropertyOf ns1:sended_by ;
    owl:equivalentProperty ns1:sended_by .

rdf:type a rdf:Property ;
    rdfs:subPropertyOf rdf:type ;
    owl:equivalentProperty rdf:type .

rdfs:domain a rdf:Property ;
    rdfs:subPropertyOf rdfs:domain ;
    owl:equivalentProperty rdfs:domain .

rdfs:range a rdf:Property ;
    rdfs:subPropertyOf rdfs:range ;
    owl:equivalentProperty rdfs:range .

rdfs:subClassOf a rdf:Property ;
    rdfs:subPropertyOf rdfs:subClassOf ;
    owl:equivalentProperty rdfs:subClassOf .

rdfs:subPropertyOf a rdf:Property ;
    rdfs:subPropertyOf rdfs:subPropertyOf ;
    owl:equivalentProperty rdfs:subPropertyOf .

owl:Nothing a owl:Class ;
    rdfs:subClassOf ns1:Person,
        owl:Nothing,
        owl:Thing ;
    owl:equivalentClass owl:Nothing .

owl:inverseOf a rdf:Property ;
    rdfs:subPropertyOf owl:inverseOf ;
    owl:equivalentProperty owl:inverseOf .

<http://esempio.org/nodo/Message_5> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "Yeah, I'm sure you'll do just fine. Mattia's always making jokes, probably just to annoy me. Do you think you'll be able to meet up with Alice tonight?" ;
    ns1:mentions <http://esempio.org/nodo/Alice>,
        <http://esempio.org/nodo/Bob>,
        <http://esempio.org/nodo/Mattia> ;
    ns1:received_at "2026-03-20T15:50:42.889000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Frank> ;
    ns1:sended_at "2026-03-20T15:50:42.888000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Bob> .

<http://esempio.org/nodo/Message_6> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "I'm sure Alice will be there, she's always up for a good time. I just hope Mattia doesn't try to make a fool of me, I don't want to look silly. What's it like, studying for your exam?" ;
    ns1:mentions <http://esempio.org/nodo/Alice>,
        <http://esempio.org/nodo/Frank>,
        <http://esempio.org/nodo/Mattia> ;
    ns1:received_at "2026-03-20T15:50:44.576000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Bob> ;
    ns1:sended_at "2026-03-20T15:50:44.576000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Frank> .

<http://esempio.org/nodo/Message_9> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "I think Liam's just trying to help, he's always looking out for you. Do you think Alice's going to be at the pub tonight, we could all go together?" ;
    ns1:mentions <http://esempio.org/nodo/Alice>,
        <http://esempio.org/nodo/Bob>,
        <http://esempio.org/nodo/Liam> ;
    ns1:received_at "2026-03-20T15:50:48.997000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Frank> ;
    ns1:sended_at "2026-03-20T15:50:48.997000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Bob> .

owl:Class a rdfs:Resource .

<http://esempio.org/nodo/Message_2> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "It's going well, just studying for my next exam. Liam's been good, always helping me with my math problems. Alice's been busy, but she promised to meet up with me tonight. What about you?" ;
    ns1:mentions <http://esempio.org/nodo/Alice>,
        <http://esempio.org/nodo/Frank>,
        <http://esempio.org/nodo/Liam>,
        <http://esempio.org/nodo/you> ;
    ns1:received_at "2026-03-20T15:50:38.660000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Bob> ;
    ns1:sended_at "2026-03-20T15:50:38.659000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Frank> .

<http://esempio.org/nodo/Message_4> a ns1:Message,
        rdfs:Resource ;
    ns1:hasText "My exam is coming up quickly, I'm planning to review my notes until the last minute. Liam's been saying I'm not studying hard enough, but Alice thinks I've got it covered. Mattia's been teasing me about being a procrastinator, but I think he just likes the drama." ;
    ns1:mentions <http://esempio.org/nodo/Alice>,
        <http://esempio.org/nodo/Frank>,
        <http://esempio.org/nodo/Liam>,
        <http://esempio.org/nodo/Mattia> ;
    ns1:received_at "2026-03-20T15:50:41.495000"^^xsd:dateTime ;
    ns1:received_by <http://esempio.org/nodo/Bob> ;
    ns1:sended_at "2026-03-20T15:50:41.495000"^^xsd:dateTime ;
    ns1:sended_by <http://esempio.org/nodo/Frank> .

